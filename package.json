{
  "name": "stias-dh-ai-workshop-2026",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "messages": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --strategy globalVariable baseLocale",
    "prepare": "npm run messages",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.65.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sharp": "^0.35.1",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@inlang/paraglide-js": "^2.19.0",
    "@lucide/svelte": "^1.18.0",
    "@skeletonlabs/skeleton": "^4.15.1",
    "@skeletonlabs/skeleton-svelte": "^4.15.1",
    "jspdf": "^4.2.1",
    "marked": "^18.0.5"
  },
  "type": "module",
  "overrides": {
    "@tailwindcss/vite": {
      "vite": "$vite"
    }
  }
}
